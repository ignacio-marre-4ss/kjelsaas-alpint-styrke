    {uke:"Uke 6", session:"Økt 1", sets:[{pct:65,reps:8},{pct:75,reps:8},{pct:87.5,reps:4}], sett:4},
    {uke:"Uke 6", session:"Økt 2", sets:[{pct:55,reps:10},{pct:65,reps:10},{pct:77.5,reps:6}], sett:3}
