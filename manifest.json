};

const WEIGHT_GATE_CHECKLIST = [
  "Er det fysisk mulig å øke kg?",
  "Er det kvalitet i bevegelsen?",
  "Er knærne i ro, pekende rett fram?",
  "Er ryggen rett?",
  "Er hele foten i bakken? Også hælen."
];

const EXERCISES = {
