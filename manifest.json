/* ================== STATE / STORAGE ================== */

const STORAGE_KEY = "kjelsaasAlpintStyrke";

function loadState(){
  try{
    const raw = localStorage.getItem(STORAGE_KEY);
    if(raw) return JSON.parse(raw);
  }catch(e){}
  return {
    athletes:[{id:"a1", name:"Meg", oneRM:{styrke1:"",styrke2:"",styrke3:""}, checklist:[false,false,false,false,false]}],
    activeId:"a1",
    logs:{a1:[]}
  };
}
let state = loadState();

function saveState(){
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
}
function activeAthlete(){
  return state.athletes.find(a=>a.id===state.activeId) || state.athletes[0];
}
function uid(){ return "id"+Date.now()+Math.floor(Math.random()*1000); }

/* ================== NAV ================== */

let currentPage = "hjem";
function goTo(page){
  currentPage = page;
  document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));
  document.getElementById("page-"+page).classList.add("active");
  document.querySelectorAll("nav.bottom button").forEach(b=>b.classList.toggle("active", b.dataset.page===page));
  if(page==="hjem") renderHome();
  if(page==="styrke") renderStrengthPage();
  if(page==="ovelser") renderExercisePage();
  if(page==="logg") renderLogPage();
  if(page==="profil") renderProfilePage();
}

function toast(msg){
  const t=document.getElementById("toast");
  t.textContent=msg;
  t.classList.add("show");
  setTimeout(()=>t.classList.remove("show"), 1800);
}

/* ================== WEEK HELPERS ================== */

function isoWeekKey(d){
  const date = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
  const dayNum = (date.getUTCDay() + 6) % 7;
  date.setUTCDate(date.getUTCDate() - dayNum + 3);
  const firstThursday = new Date(Date.UTC(date.getUTCFullYear(),0,4));
  const weekNum = 1 + Math.round(((date - firstThursday) / 86400000 - 3 + ((firstThursday.getUTCDay()+6)%7)) / 7);
  return date.getUTCFullYear()+"-W"+weekNum;
}
function currentWeekLabel(){
  const k = isoWeekKey(new Date());
  return "Uke " + k.split("-W")[1];
}

/* ================== HOME PAGE ================== */

function renderHome(){
  document.getElementById("weekLabel").textContent = currentWeekLabel();
  const athlete = activeAthlete();
  const logs = state.logs[athlete.id] || [];
  const thisWeekKey = isoWeekKey(new Date());
  const weekLogs = logs.filter(l => isoWeekKey(new Date(l.date)) === thisWeekKey);

  const counts = {};
  WEEK_GOALS.forEach(g=>counts[g.key]=0);
  weekLogs.forEach(l=>{ if(counts[l.type] !== undefined) counts[l.type]++; });

  const wrap = document.getElementById("weekGoalsList");
  wrap.innerHTML = WEEK_GOALS.map(g=>{
    const count = counts[g.key];
    const done = count >= g.min;
    return `<div class="goal-row">
      <div><div class="label">${g.label}</div><div class="sub">Mål: ${g.min===g.max ? g.min : g.min+'–'+g.max} / uke</div></div>
      <div class="progress-pill ${done?'done':''}">${count} / ${g.min===g.max ? g.min : g.max}</div>
    </div>`;
  }).join("");
}

/* ================== STRENGTH PAGE ================== */

let activeStrengthTable = "styrke1";

function calcWeight(oneRM, pct){
  if(!oneRM || isNaN(oneRM)) return null;
  return Math.round(((oneRM*pct)/100)/2.5)*2.5;
}

function renderStrengthTabs(){
  const wrap = document.getElementById("strengthTabs");
  wrap.innerHTML = Object.keys(STRENGTH_TABLES).map(key=>{
    return `<button class="${key===activeStrengthTable?'active':''}" onclick="switchStrengthTable('${key}')">${STRENGTH_TABLES[key].label}</button>`;
  }).join("");
}
function switchStrengthTable(key){
  activeStrengthTable = key;
  renderStrengthTabs();
  renderStrengthTable();
}

function renderStrengthTable(){
  const athlete = activeAthlete();
  const input = document.getElementById("oneRmInput");
  input.value = athlete.oneRM[activeStrengthTable] || "";
  const table = STRENGTH_TABLES[activeStrengthTable];
  const oneRM = parseFloat(input.value);

  const hasWeeks = table.rows.some(r=>r.uke);
  let html = `<table class="plan"><thead><tr>`;
  if(hasWeeks) html += `<th>Uke</th>`;
  html += `<th>Økt</th><th>%</th><th>Vekt</th><th>Reps</th><th>%</th><th>Vekt</th><th>Reps</th><th>%</th><th>Vekt</th><th>Reps</th><th>Sett</th></tr></thead><tbody>`;
  table.rows.forEach(row=>{
    html += `<tr>`;
    if(hasWeeks) html += `<td class="week-cell">${row.uke || ""}</td>`;
    html += `<td class="session-cell">${row.session}</td>`;
    row.sets.forEach(s=>{
      const w = calcWeight(oneRM, s.pct);
      html += `<td>${s.pct}%</td><td class="weight-cell">${w!==null ? w+' kg' : '–'}</td><td>${s.reps}</td>`;
    });
    html += `<td>${row.sett}</td></tr>`;
  });
  html += `</tbody></table>`;
  document.getElementById("strengthTableWrap").innerHTML = html;
}

function onOneRmChange(){
  const athlete = activeAthlete();
  const v = document.getElementById("oneRmInput").value;
  athlete.oneRM[activeStrengthTable] = v;
  saveState();
  renderStrengthTable();
}

function renderChecklist(){
  const athlete = activeAthlete();
  if(!athlete.checklist) athlete.checklist = [false,false,false,false,false];
  const wrap = document.getElementById("checklistWrap");
  wrap.innerHTML = WEIGHT_GATE_CHECKLIST.map((item,i)=>{
    return `<div class="checklist-item">
      <input type="checkbox" id="chk${i}" ${athlete.checklist[i]?'checked':''} onchange="toggleChecklist(${i})">
      <span>${item}</span>
    </div>`;
  }).join("");
  const allChecked = athlete.checklist.every(v=>v);
  const banner = document.getElementById("gateBanner");
  banner.className = "gate-banner " + (allChecked ? "unlocked":"locked");
  banner.textContent = allChecked ? "✓ Klar til å øke kg neste økt" : "Ikke klar for vektøkning ennå";
}
function toggleChecklist(i){
  const athlete = activeAthlete();
  athlete.checklist[i] = !athlete.checklist[i];
  saveState();
  renderChecklist();
}

function renderStrengthPage(){
  renderStrengthTabs();
  renderStrengthTable();
  renderChecklist();
  document.getElementById("oneRmInput").oninput = onOneRmChange;
}

/* ================== EXERCISE PAGE ================== */

let activeExerciseTab = "beinstyrke";

function renderExerciseTabs(){
  const wrap = document.getElementById("exerciseTabs");
  wrap.innerHTML = Object.keys(EXERCISES).map(key=>{
    return `<button class="${key===activeExerciseTab?'active':''}" onclick="switchExerciseTab('${key}')">${EXERCISES[key].label}</button>`;
  }).join("");
}
function switchExerciseTab(key){
  activeExerciseTab = key;
  renderExerciseTabs();
  renderExerciseContent();
}

function renderExerciseContent(){
  const data = EXERCISES[activeExerciseTab];
  let html = `<div class="card"><p class="hint">${data.intro || ""}</p>`;

  if(data.groups){
    data.groups.forEach(g=>{
      html += `<h3>${g.title}</h3>`;
      if(g.note) html += `<p class="hint">${g.note}</p>`;
      g.items.forEach(it=>{
        html += `<div class="exercise"><div class="name">${it.name}</div>${it.meta?`<div class="meta">${it.meta}</div>`:''}</div>`;
      });
    });
  }
  if(data.intervals){
    data.intervals.forEach(iv=>{
      html += `<div class="interval-block"><div class="title">${iv.name}</div>
        <div class="row"><span>Oppvarming</span><span>${iv.warmup}</span></div>
        <div class="row"><span>Hoveddel</span><span style="text-align:right">${iv.main}</span></div>
        <div class="row"><span>Avslutning</span><span>${iv.cooldown}</span></div>
      </div>`;
    });
  }
  if(data.items){
    data.items.forEach(it=>{
      html += `<div class="exercise"><div class="name">${it.name}</div>${it.meta?`<div class="meta">${it.meta}</div>`:''}</div>`;
    });
  }
  if(data.video){
    html += `<a class="link-btn" href="${data.video}" target="_blank" rel="noopener">▶ Se video</a>`;
  }
  if(data.videos){
    data.videos.forEach((v,i)=>{
      html += `<a class="link-btn" href="${v}" target="_blank" rel="noopener">▶ Se video ${i+1}</a>`;
    });
  }
  html += `</div>`;
  document.getElementById("exerciseContent").innerHTML = html;
}

function renderExercisePage(){
  renderExerciseTabs();
  renderExerciseContent();
}

/* ================== LOG PAGE ================== */

function openLogModal(){
  document.getElementById("logDate").value = new Date().toISOString().slice(0,10);
  document.getElementById("logNotes").value = "";
  document.getElementById("logType").value = "beinstyrke";
  document.getElementById("logModal").classList.add("open");
}
function closeModal(id){
  document.getElementById(id).classList.remove("open");
}
function saveLog(){
  const athlete = activeAthlete();
  if(!state.logs[athlete.id]) state.logs[athlete.id] = [];
  state.logs[athlete.id].unshift({
    id: uid(),
    date: document.getElementById("logDate").value,
    type: document.getElementById("logType").value,
    notes: document.getElementById("logNotes").value
  });
  saveState();
  closeModal("logModal");
  toast("Økt logget");
  if(currentPage==="logg") renderLogPage();
  if(currentPage==="hjem") renderHome();
}
function deleteLog(id){
  const athlete = activeAthlete();
  state.logs[athlete.id] = (state.logs[athlete.id]||[]).filter(l=>l.id!==id);
  saveState();
  renderLogPage();
}

const TYPE_LABELS = {
  beinstyrke:"Beinstyrke", intervall:"Intervall", langtur:"Rolig langkjør",
  spenst:"Spenst / hurtighet / koordinasjon", core:"Core", mobilitet:"Mobilitet / tøyning", annet:"Annet / fridag"
};

function renderLogPage(){
  const athlete = activeAthlete();
  const logs = (state.logs[athlete.id]||[]).slice().sort((a,b)=> b.date.localeCompare(a.date));
  const wrap = document.getElementById("logList");
  if(logs.length===0){
    wrap.innerHTML = `<div class="empty">Ingen økter logget ennå for ${athlete.name}.</div>`;
    return;
  }
  wrap.innerHTML = logs.map(l=>{
    const d = new Date(l.date);
    const dateStr = isNaN(d) ? l.date : d.toLocaleDateString('nb-NO',{day:'2-digit',month:'short',year:'numeric'});
    return `<div class="log-entry">
      <button class="del" onclick="deleteLog('${l.id}')">Slett</button>
      <div class="top">${dateStr}</div>
      <div class="type">${TYPE_LABELS[l.type]||l.type}</div>
      ${l.notes?`<div class="notes">${l.notes.replace(/</g,'&lt;')}</div>`:''}
    </div>`;
  }).join("");
}

/* ================== PROFILE / ATHLETES ================== */

function renderAthleteChip(a, inModal){
  const active = a.id === state.activeId;
  return `<div class="athlete-chip ${active?'active-chip':''}" onclick="${inModal?`selectAthlete('${a.id}')`:''}">
    <span>${a.name}${active?' ✓':''}</span>
    ${state.athletes.length>1 ? `<button class="remove" onclick="event.stopPropagation();removeAthlete('${a.id}')">Fjern</button>` : ''}
  </div>`;
}
function renderProfilePage(){
  document.getElementById("athleteListFull").innerHTML = state.athletes.map(a=>renderAthleteChip(a,true)).join("");
}
function openAthleteModal(){
  document.getElementById("athleteListModal").innerHTML = state.athletes.map(a=>renderAthleteChip(a,true)).join("");
  document.getElementById("athleteModal").classList.add("open");
}
function selectAthlete(id){
  state.activeId = id;
  saveState();
  updateAthleteBtn();
  closeModal("athleteModal");
  goTo(currentPage);
}
function addAthlete(){
  const nameInput = document.getElementById("newAthleteName");
  const name = nameInput.value.trim();
  if(!name){ toast("Skriv inn et navn"); return; }
  const id = uid();
  state.athletes.push({id, name, oneRM:{styrke1:"",styrke2:"",styrke3:""}, checklist:[false,false,false,false,false]});
  state.logs[id] = [];
  nameInput.value = "";
  saveState();
  renderProfilePage();
  toast("Utøver lagt til");
}
function removeAthlete(id){
  if(state.athletes.length<=1) return;
  state.athletes = state.athletes.filter(a=>a.id!==id);
  delete state.logs[id];
  if(state.activeId===id) state.activeId = state.athletes[0].id;
  saveState();
  updateAthleteBtn();
  renderProfilePage();
}
function updateAthleteBtn(){
  document.getElementById("athleteBtn").textContent = activeAthlete().name;
}
function resetAllData(){
  if(confirm("Slette all lagret treningsdata på denne enheten?")){
    localStorage.removeItem(STORAGE_KEY);
    state = loadState();
    updateAthleteBtn();
    goTo(currentPage);
    toast("Data nullstilt");
  }
}

/* ================== INIT ================== */

function init(){
  updateAthleteBtn();
  goTo("hjem");
  if("serviceWorker" in navigator){
    navigator.serviceWorker.register("sw.js").catch(()=>{});
  }
}
init();
</script>
