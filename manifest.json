<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">
<title>Kjelsås Alpint Styrke</title>
<meta name="theme-color" content="#0f2d5c">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="KA Styrke">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/apple-touch-icon.png">
<link rel="icon" href="icons/icon-192.png">
<style>
  :root{
    --navy:#0f2d5c;
    --navy-dark:#0a1f42;
    --blue-light:#e6edf7;
    --blue-mid:#c9d9ee;
    --accent:#2f6fb0;
    --white:#ffffff;
    --ok:#1e8e5a;
    --warn:#c0392b;
    --text:#152538;
    --muted:#5b6b80;
    --radius:16px;
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html,body{margin:0;padding:0;height:100%;}
  body{
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:var(--blue-light);
    color:var(--text);
    padding-bottom:env(safe-area-inset-bottom);
    overscroll-behavior-y:contain;
  }
  header.topbar{
    background:var(--navy);
    color:var(--white);
    padding:calc(14px + env(safe-area-inset-top)) 16px 14px;
    display:flex;
    align-items:center;
    gap:10px;
    position:sticky;
    top:0;
    z-index:20;
    box-shadow:0 2px 8px rgba(0,0,0,0.15);
  }
  header.topbar img{width:36px;height:36px;border-radius:9px;flex-shrink:0;}
  header.topbar .titles{flex:1;min-width:0;}
  header.topbar h1{font-size:15px;margin:0;font-weight:700;letter-spacing:.2px;}
  header.topbar .sub{font-size:11px;opacity:.8;margin-top:1px;}
  header.topbar button.athlete-btn{
    background:rgba(255,255,255,0.14);
    border:none;
    color:var(--white);
    font-size:12px;
    font-weight:600;
    padding:8px 12px;
    border-radius:20px;
    max-width:120px;
    overflow:hidden;
    text-overflow:ellipsis;
    white-space:nowrap;
  }
  main{padding:14px 14px 90px;max-width:640px;margin:0 auto;}
  .page{display:none;}
  .page.active{display:block;animation:fade .18s ease;}
  @keyframes fade{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:none;}}
  .card{
    background:var(--white);
    border-radius:var(--radius);
    padding:16px;
    margin-bottom:14px;
    box-shadow:0 1px 3px rgba(15,45,92,0.08);
  }
  .card h2{margin:0 0 4px;font-size:17px;color:var(--navy);}
  .card h3{margin:0 0 8px;font-size:14px;color:var(--navy);}
  .card p.hint{margin:0 0 10px;font-size:12.5px;color:var(--muted);line-height:1.4;}
  .goal-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--blue-light);gap:10px;}
  .goal-row:last-child{border-bottom:none;}
  .goal-row .label{font-size:13.5px;font-weight:600;}
  .goal-row .sub{font-size:11.5px;color:var(--muted);font-weight:400;}
  .progress-pill{
    font-size:12px;font-weight:700;padding:5px 10px;border-radius:20px;
    background:var(--blue-light);color:var(--navy);white-space:nowrap;
  }
  .progress-pill.done{background:#e3f4ea;color:var(--ok);}
  .stepper{display:flex;align-items:center;gap:8px;}
  .stepper button{
    width:30px;height:30px;border-radius:50%;border:none;background:var(--navy);color:#fff;
    font-size:16px;font-weight:700;display:flex;align-items:center;justify-content:center;
  }
  .stepper button:active{background:var(--navy-dark);}
  .tabs{display:flex;gap:6px;overflow-x:auto;margin-bottom:12px;padding-bottom:2px;}
  .tabs button{
    flex-shrink:0;border:none;background:var(--white);color:var(--navy);
    font-size:12.5px;font-weight:600;padding:8px 14px;border-radius:20px;
    box-shadow:0 1px 3px rgba(15,45,92,0.1);
  }
  .tabs button.active{background:var(--navy);color:#fff;}
  select,input[type=number],input[type=text],input[type=date],textarea{
    width:100%;padding:10px 12px;border-radius:10px;border:1.5px solid var(--blue-mid);
    font-size:14.5px;background:#fbfcfe;color:var(--text);font-family:inherit;
  }
  textarea{resize:vertical;min-height:60px;}
  label.field-label{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.3px;display:block;margin:10px 0 5px;}
  table.plan{width:100%;border-collapse:collapse;font-size:12.5px;margin-top:8px;}
  table.plan th{background:var(--navy);color:#fff;padding:7px 4px;font-size:10.5px;text-transform:uppercase;letter-spacing:.3px;}
  table.plan td{padding:7px 4px;text-align:center;border-bottom:1px solid var(--blue-light);}
  table.plan tr:nth-child(even) td{background:#f7fafd;}
  table.plan td.session-cell{text-align:left;font-weight:700;color:var(--navy);}
  table.plan td.week-cell{font-weight:700;color:var(--accent);}
  .weight-cell{font-weight:700;color:var(--navy);}
  .checklist-item{display:flex;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid var(--blue-light);}
  .checklist-item:last-child{border-bottom:none;}
  .checklist-item input{width:20px;height:20px;flex-shrink:0;margin-top:1px;accent-color:var(--navy);}
  .checklist-item span{font-size:13.5px;line-height:1.4;}
  .gate-banner{margin-top:12px;padding:10px 12px;border-radius:10px;font-size:13px;font-weight:700;text-align:center;}
  .gate-banner.locked{background:#fbe9e7;color:var(--warn);}
  .gate-banner.unlocked{background:#e3f4ea;color:var(--ok);}
  .exercise{border-bottom:1px solid var(--blue-light);padding:10px 0;}
  .exercise:last-child{border-bottom:none;}
  .exercise .name{font-weight:700;font-size:13.5px;color:var(--navy);}
  .exercise .meta{font-size:12px;color:var(--muted);margin-top:2px;}
  .btn{
    display:inline-block;width:100%;text-align:center;background:var(--navy);color:#fff;
    border:none;padding:12px;border-radius:12px;font-size:14.5px;font-weight:700;margin-top:8px;
  }
  .btn:active{background:var(--navy-dark);}
  .btn.secondary{background:var(--blue-light);color:var(--navy);}
  .btn.danger{background:#fbe9e7;color:var(--warn);}
  .link-btn{display:block;font-size:12.5px;color:var(--accent);font-weight:600;text-decoration:none;margin-top:4px;}
  ul.plain{margin:6px 0 0;padding-left:18px;font-size:13px;line-height:1.6;}
  .interval-block{background:var(--blue-light);border-radius:12px;padding:10px 12px;margin-bottom:10px;}
  .interval-block .title{font-weight:700;color:var(--navy);font-size:13.5px;margin-bottom:4px;}
  .interval-block .row{font-size:12.5px;display:flex;justify-content:space-between;padding:2px 0;}
  .log-entry{border-left:4px solid var(--navy);background:var(--blue-light);border-radius:0 10px 10px 0;padding:10px 12px;margin-bottom:10px;}
  .log-entry .top{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);font-weight:700;}
  .log-entry .type{font-size:14px;font-weight:700;color:var(--navy);margin:2px 0 4px;}
  .log-entry .notes{font-size:12.5px;color:var(--text);}
  .log-entry .del{float:right;color:var(--warn);font-size:11.5px;font-weight:700;background:none;border:none;}
  .empty{font-size:13px;color:var(--muted);text-align:center;padding:20px 0;}
  nav.bottom{
    position:fixed;bottom:0;left:0;right:0;background:#fff;
    display:flex;border-top:1px solid var(--blue-mid);
    padding-bottom:env(safe-area-inset-bottom);z-index:20;
  }
  nav.bottom button{
    flex:1;background:none;border:none;padding:9px 0 8px;font-size:10.5px;font-weight:700;
    color:var(--muted);display:flex;flex-direction:column;align-items:center;gap:3px;
  }
  nav.bottom button .ic{font-size:19px;}
  nav.bottom button.active{color:var(--navy);}
  .athlete-list{display:flex;flex-direction:column;gap:8px;}
  .athlete-chip{
    display:flex;align-items:center;justify-content:space-between;padding:11px 14px;
    background:var(--blue-light);border-radius:12px;font-size:14px;font-weight:600;
  }
  .athlete-chip.active-chip{background:var(--navy);color:#fff;}
  .athlete-chip button.remove{background:none;border:none;color:inherit;opacity:.6;font-size:12px;font-weight:700;}
  .modal-overlay{
    position:fixed;inset:0;background:rgba(10,25,50,0.5);display:none;
    align-items:flex-end;justify-content:center;z-index:50;
  }
  .modal-overlay.open{display:flex;}
  .modal{background:#fff;border-radius:18px 18px 0 0;padding:18px 16px calc(20px + env(safe-area-inset-bottom));width:100%;max-width:640px;max-height:85vh;overflow-y:auto;}
  .modal h3{margin:0 0 12px;color:var(--navy);}
  .row-2{display:flex;gap:10px;}
  .row-2 > div{flex:1;}
  .toast{
    position:fixed;bottom:80px;left:50%;transform:translateX(-50%);
    background:var(--navy-dark);color:#fff;padding:9px 16px;border-radius:20px;
    font-size:12.5px;font-weight:600;opacity:0;pointer-events:none;transition:opacity .2s;z-index:60;
  }
  .toast.show{opacity:1;}
  .week-badge{font-size:11px;color:var(--muted);font-weight:600;}
</style>
</head>
<body>

<header class="topbar">
  <img src="icons/icon-192.png" alt="Kjelsås Alpint">
  <div class="titles">
    <h1>Kjelsås Alpint Styrke</h1>
    <div class="sub" id="weekLabel">Uke –</div>
  </div>
  <button class="athlete-btn" id="athleteBtn" onclick="openAthleteModal()">Utøver</button>
</header>

<main>

  <!-- HJEM -->
  <section class="page" id="page-hjem">
    <div class="card">
      <h2>Mål for sommeren</h2>
      <p class="hint">Bedre kondisjon, styrke og bevegelighet. (Fra treningsplan – Kjelsås Alpint)</p>
    </div>

    <div class="card">
      <h3>Denne uken</h3>
      <p class="hint">Ukemål hentet direkte fra treneren sitt program.</p>
      <div id="weekGoalsList"></div>
    </div>

    <div class="card">
      <h3>Sommerutfordring</h3>
      <p class="hint">Lær deg noe nytt i sommer – hva som helst! Slakkline, sjonglering, vannski, kiting, tennis, skateboard, gå på hendene, klatring osv.</p>
    </div>

    <div class="card">
      <h3>Hurtiglogg</h3>
      <p class="hint">Registrer en gjennomført økt på under 10 sekunder.</p>
      <button class="btn" onclick="goTo('logg');openLogModal()">+ Logg økt</button>
    </div>
  </section>

  <!-- STYRKE -->
  <section class="page" id="page-styrke">
    <div class="card">
      <h3>1RM-basert vektberegning</h3>
      <p class="hint">Gjenskaper treneren sitt Excel-skjema. Skriv inn 1RM (kg) i knebøy/markløft, så beregnes oppvarmingsvekter og arbeidsvekt for hver økt automatisk – avrundet til nærmeste 2.5 kg.</p>
      <div class="tabs" id="strengthTabs"></div>
      <label class="field-label">1RM (kg) for denne tabellen</label>
      <input type="number" id="oneRmInput" inputmode="decimal" placeholder="f.eks. 85" step="2.5">
      <div id="strengthTableWrap"></div>
    </div>

    <div class="card">
      <h3>Sjekkliste før du øker kg</h3>
      <p class="hint">Fra treneren: dette må være på plass før du øker vekt i knebøy, markløft og strakmark.</p>
      <div id="checklistWrap"></div>
      <div class="gate-banner" id="gateBanner"></div>
    </div>
  </section>

  <!-- ØVELSER -->
  <section class="page" id="page-ovelser">
    <div class="tabs" id="exerciseTabs"></div>
    <div id="exerciseContent"></div>
  </section>

  <!-- LOGG -->
  <section class="page" id="page-logg">
    <div class="card">
      <h3>Treningslogg</h3>
      <p class="hint">Alle registrerte økter for valgt utøver, lagret lokalt på denne telefonen.</p>
      <button class="btn" onclick="openLogModal()">+ Ny logg</button>
    </div>
    <div id="logList"></div>
  </section>

  <!-- PROFIL -->
  <section class="page" id="page-profil">
    <div class="card">
      <h3>Utøvere</h3>
      <p class="hint">Legg til flere utøvere. Alt lagres lokalt på denne telefonen/nettleseren – ingen innlogging eller sky-synk.</p>
      <div class="athlete-list" id="athleteListFull"></div>
      <label class="field-label">Ny utøver</label>
      <div class="row-2">
        <div><input type="text" id="newAthleteName" placeholder="Navn"></div>
      </div>
      <button class="btn secondary" onclick="addAthlete()">+ Legg til utøver</button>
    </div>
    <div class="card" style="text-align:center;">
      <img src="icons/wordmark.png" alt="Kjelsås Alpint" style="width:140px;border-radius:14px;margin-bottom:10px;">
      <h3>Om appen</h3>
      <p class="hint">Kjelsås Alpint Styrke er bygget direkte fra treningsprogrammet «Sommertrening» og vektskjemaet fra skitreneren – ingen AI-genererte økter er lagt til. Fungerer offline og kan installeres på hjem-skjermen på både iPhone og Android.</p>
      <button class="btn danger" onclick="resetAllData()">Nullstill all data</button>
    </div>
  </section>

</main>

<nav class="bottom">
  <button data-page="hjem" onclick="goTo('hjem')"><span class="ic">🏠</span>Hjem</button>
  <button data-page="styrke" onclick="goTo('styrke')"><span class="ic">🏋️</span>Styrke</button>
  <button data-page="ovelser" onclick="goTo('ovelser')"><span class="ic">📋</span>Øvelser</button>
  <button data-page="logg" onclick="goTo('logg')"><span class="ic">🗒️</span>Logg</button>
  <button data-page="profil" onclick="goTo('profil')"><span class="ic">👤</span>Profil</button>
</nav>

<!-- ATHLETE SWITCH MODAL -->
<div class="modal-overlay" id="athleteModal">
  <div class="modal">
    <h3>Bytt utøver</h3>
    <div class="athlete-list" id="athleteListModal"></div>
    <button class="btn secondary" onclick="closeModal('athleteModal')">Lukk</button>
  </div>
</div>

<!-- LOG MODAL -->
<div class="modal-overlay" id="logModal">
  <div class="modal">
    <h3>Logg økt</h3>
    <label class="field-label">Dato</label>
    <input type="date" id="logDate">
    <label class="field-label">Type økt</label>
    <select id="logType">
      <option value="beinstyrke">Beinstyrke</option>
      <option value="intervall">Intervall</option>
      <option value="langtur">Rolig langkjør</option>
      <option value="spenst">Spenst / hurtighet / koordinasjon</option>
      <option value="core">Core</option>
      <option value="mobilitet">Mobilitet / tøyning</option>
      <option value="annet">Annet / fridag</option>
    </select>
    <label class="field-label">Notater (vekt, reps, følelse osv.)</label>
    <textarea id="logNotes" placeholder="f.eks. Knebøy 60kg 3x8, kjentes bra..."></textarea>
    <button class="btn" onclick="saveLog()">Lagre logg</button>
    <button class="btn secondary" onclick="closeModal('logModal')">Avbryt</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
/* ================== DATA (fra sommertrening.pdf og Vekttabell_Styrke_1_MAL_NTG.xlsx) ================== */

const WEEK_GOALS = [
  {key:"beinstyrke", label:"Beinstyrke økter", min:2, max:3},
  {key:"intervall", label:"Intervall", min:1, max:1},
  {key:"langtur", label:"Rolig langkjør", min:1, max:1},
  {key:"spenst", label:"Spenst / hurtighet / koordinasjon", min:1, max:2},
  {key:"annet", label:"Fridager", min:1, max:2}
];

function pctRow(sets, sett){ return {sets, sett}; }

const STRENGTH_TABLES = {
  styrke1: { label:"Styrke 1", rows:[
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:65,reps:8},{pct:70,reps:6}], sett:4},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:55,reps:12},{pct:60,reps:10}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:65,reps:9},{pct:72.5,reps:6}], sett:4},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:55,reps:13},{pct:62.5,reps:10}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:65,reps:10},{pct:75,reps:6}], sett:4},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:55,reps:14},{pct:65,reps:10}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:65,reps:9},{pct:72.5,reps:6}], sett:4},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:55,reps:13},{pct:62.5,reps:10}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:65,reps:10},{pct:75,reps:6}], sett:4},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:55,reps:14},{pct:65,reps:10}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:65,reps:11},{pct:77.5,reps:6}], sett:4},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:55,reps:15},{pct:67.5,reps:10}], sett:3}
  ]},
  styrke2: { label:"Styrke 2", rows:[
    {session:"Økt 1", sets:[{pct:50,reps:12},{pct:60,reps:10},{pct:70,reps:8}], sett:3},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:60,reps:10},{pct:65,reps:8}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:70,reps:7},{pct:77.5,reps:5}], sett:3},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:60,reps:11},{pct:67.5,reps:8}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:70,reps:8},{pct:80,reps:5}], sett:3},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:60,reps:12},{pct:70,reps:8}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:70,reps:7},{pct:77.5,reps:5}], sett:3},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:60,reps:11},{pct:67.5,reps:8}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:70,reps:8},{pct:80,reps:5}], sett:3},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:60,reps:12},{pct:70,reps:8}], sett:3},
    {session:"Økt 1", sets:[{pct:60,reps:10},{pct:70,reps:9},{pct:82.5,reps:5}], sett:3},
    {session:"Økt 2", sets:[{pct:50,reps:15},{pct:60,reps:13},{pct:72.5,reps:8}], sett:3}
  ]},
  styrke3: { label:"Styrke 3", rows:[
    {uke:"Uke 1", session:"Økt 1", sets:[{pct:65,reps:8},{pct:75,reps:5},{pct:80,reps:4}], sett:4},
    {uke:"Uke 1", session:"Økt 2", sets:[{pct:55,reps:10},{pct:65,reps:7},{pct:70,reps:6}], sett:3},
    {uke:"Uke 2", session:"Økt 1", sets:[{pct:65,reps:8},{pct:75,reps:6},{pct:82.5,reps:4}], sett:4},
    {uke:"Uke 2", session:"Økt 2", sets:[{pct:55,reps:10},{pct:65,reps:8},{pct:72.5,reps:6}], sett:3},
    {uke:"Uke 3", session:"Økt 1", sets:[{pct:65,reps:8},{pct:75,reps:7},{pct:85,reps:4}], sett:4},
    {uke:"Uke 3", session:"Økt 2", sets:[{pct:55,reps:10},{pct:65,reps:9},{pct:75,reps:6}], sett:3},
    {uke:"Uke 4", session:"Økt 1", sets:[{pct:65,reps:8},{pct:75,reps:6},{pct:82.5,reps:4}], sett:4},
    {uke:"Uke 4", session:"Økt 2", sets:[{pct:55,reps:10},{pct:65,reps:8},{pct:72.5,reps:6}], sett:3},
    {uke:"Uke 5", session:"Økt 1", sets:[{pct:65,reps:8},{pct:75,reps:7},{pct:85,reps:4}], sett:4},
